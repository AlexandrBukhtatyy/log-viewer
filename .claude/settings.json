{
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/adr-reminder.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Edit(src/**)"
    ],
    "deny": ["Read(.env*)", "Read(**/credentials*)"]
  },
  "plansDirectory": "./docs/plans",
  "respectGitignore": true
}
