{
  "name": "@abukhtatyy/log-viewer",
  "version": "0.1.2",
  "description": "Self-hosted PWA log viewer — runs entirely client-side (OPFS + sqlite-wasm). Ships a bundled HTTP server for on-prem / Docker deploys in air-gapped networks.",
  "license": "MIT",
  "author": "Alexandr Bukhtatyy",
  "homepage": "https://alexandrbukhtatyy.github.io/log-viewer/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexandrBukhtatyy/log-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/AlexandrBukhtatyy/log-viewer/issues"
  },
  "keywords": [
    "log-viewer",
    "logs",
    "pwa",
    "jsonl",
    "sqlite",
    "opfs",
    "offline",
    "self-hosted",
    "on-prem"
  ],
  "type": "module",
  "bin": {
    "log-viewer": "./bin/cli.mjs"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./bin/cli.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:onprem": "tsc -b && BUILD_TARGET=onprem vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:fixtures": "node scripts/gen-fixtures.mjs"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "@tanstack/react-virtual": "^3.13.24",
    "comlink": "^4.4.2",
    "fflate": "^0.8.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "workbox-window": "^7.4.1"
  }
}
